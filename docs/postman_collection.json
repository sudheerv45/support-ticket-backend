{
  "info": {
    "name": "AI Support Ticket API",
    "description": "Complete API collection for AI-Powered Support Ticket System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"Password123\", \"name\": \"John Doe\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@system.com\", \"password\": \"admin123\"}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/tickets",
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Cannot login to account\", \"description\": \"I am unable to login with correct credentials\", \"category\": \"technical\", \"priority\": \"high\"}"
            }
          }
        },
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/tickets?page=1&limit=10&status=open",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "open" }
              ]
            }
          }
        },
        {
          "name": "Get Ticket",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tickets/{{ticket_id}}"
          }
        },
        {
          "name": "Update Ticket",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/tickets/{{ticket_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"in-progress\", \"priority\": \"urgent\"}"
            }
          }
        },
        {
          "name": "Assign Ticket",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/tickets/{{ticket_id}}/assign",
            "body": {
              "mode": "raw",
              "raw": "{\"agentId\": \"{{agent_id}}\"}"
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/tickets/{{ticket_id}}/comments",
            "body": {
              "mode": "raw",
              "raw": "{\"content\": \"Looking into this issue now\", \"isInternal\": false}"
            }
          }
        },
        {
          "name": "Generate AI Summary",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tickets/{{ticket_id}}/summary"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Categorize",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/ai/categorize",
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Payment failed on checkout\", \"description\": \"Getting error 500 when trying to pay\"}"
            }
          }
        },
        {
          "name": "Analyze Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/ai/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Server down\", \"description\": \"Production server is not responding to any requests since 2 AM\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/admin/users/{{user_id}}/role",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"agent\"}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "ticket_id", "value": "" },
    { "key": "agent_id", "value": "" },
    { "key": "user_id", "value": "" }
  ]
}
